<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/xanh_dam_chuyen_nghiep" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_ten_xe_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên phương tiện"
                android:textColor="#333333"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_loai_xe_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại xe"
                android:textColor="#888888"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txt_bien_so_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#E3F2FD"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="BIỂN SỐ"
                android:textColor="@color/xanh_dam_chuyen_nghiep"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_xoa_xe"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            android:padding="8dp"
            app:tint="#FF5252" />
    </LinearLayout>
</androidx.cardview.widget.CardView>