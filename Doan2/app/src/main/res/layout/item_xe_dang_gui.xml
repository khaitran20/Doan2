<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <TextView
            android:id="@+id/txtViTri"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vị trí: A-01"
            android:textColor="#E91E63"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtThongTinXe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Honda Vision - 64B1-12345"
            android:textColor="#000000"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtChiDan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Chỉ dẫn: Lối vào chính, đi thẳng..."
            android:textColor="#757575"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/txtTien"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạm tính: 20,000đ"
            android:textColor="#2E7D32"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>