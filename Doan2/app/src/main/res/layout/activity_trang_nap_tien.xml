<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nen_xam"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/trang"
        android:paddingHorizontal="15dp">
        <ImageButton
            android:id="@+id/btn_back_dat_cho"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/xanh_dam_chuyen_nghiep" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="NẠP TIỀN VÀO VÍ"
            android:textColor="@color/xanh_dam_chuyen_nghiep"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="15dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient_xanh_the"
                    android:padding="20dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số dư hiện tại"
                        android:textColor="#D1D1D1" />
                    <TextView
                        android:id="@+id/txtSoDuHienTai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="150.000 VNĐ"
                        android:textColor="@color/trang"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="Nhập số tiền cần nạp"
                android:textStyle="bold"
                android:textColor="@color/chu_tieude"/>

            <EditText
                android:id="@+id/edtSoTienNap"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_o_nhap_tien"
                android:hint="0"
                android:inputType="number"
                android:paddingHorizontal="20dp"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/xanh_dam_chuyen_nghiep" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:columnCount="3"
                android:rowCount="1">
                <Button android:id="@+id/btn20k" android:layout_columnWeight="1" android:text="20.000" style="@style/Widget.AppCompat.Button.Borderless" android:background="@drawable/bg_chip_tien" android:layout_margin="4dp"/>
                <Button android:id="@+id/btn50k" android:layout_columnWeight="1" android:text="50.000" style="@style/Widget.AppCompat.Button.Borderless" android:background="@drawable/bg_chip_tien" android:layout_margin="4dp"/>
                <Button android:id="@+id/btn100k" android:layout_columnWeight="1" android:text="100.000" style="@style/Widget.AppCompat.Button.Borderless" android:background="@drawable/bg_chip_tien" android:layout_margin="4dp"/>
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="Chọn phương thức thanh toán"
                android:textStyle="bold"
                android:textColor="@color/chu_tieude"/>

            <RadioGroup
                android:id="@+id/rgPhuongThuc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <RelativeLayout
                    android:id="@+id/khung_momo"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_item_payment"
                    android:paddingHorizontal="15dp">

                    <ImageView
                        android:id="@+id/img_momo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/logomomo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="15dp"
                        android:layout_toEndOf="@id/img_momo"
                        android:text="Ví MoMo"
                        android:textColor="@color/chu_tieude"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/rbMomo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/khung_zalopay"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:background="@drawable/bg_item_payment"
                    android:paddingHorizontal="15dp">

                    <ImageView
                        android:id="@+id/img_zalopay"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/logo_zalopay" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="15dp"
                        android:layout_toEndOf="@id/img_zalopay"
                        android:text="ZaloPay"
                        android:textColor="@color/chu_tieude"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/rbZaloPay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>
            </RadioGroup>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnXacNhanNap"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_margin="20dp"
        android:background="@color/xanh_dam_chuyen_nghiep"
        android:text="XÁC NHẬN NẠP TIỀN"
        android:textColor="@color/trang"
        android:textSize="16sp"
        android:textStyle="bold" />
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</LinearLayout>