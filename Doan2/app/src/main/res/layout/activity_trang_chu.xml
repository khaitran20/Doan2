<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nen_xam"
    tools:context=".TrangChu">


    <RelativeLayout
        android:id="@+id/khung_tieude"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@color/trang"
        android:elevation="4dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/anh_logo"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_centerVertical="true"
            android:src="@drawable/logo6" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="TRANG CHỦ"
            android:textColor="@color/xanh_dam_chuyen_nghiep"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/khung_menu_duoi"
        app:layout_constraintTop_toBottomOf="@+id/khung_tieude">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/the_thanh_vien"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_xanh_the"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xin chào khách hàng"
                            android:textColor="#D1D1D1"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/txtTenNguoiDung"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đang tải..."
                            android:textColor="@color/trang"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="15dp"
                        android:background="#80FFFFFF" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Số dư ví của bạn:"
                                android:textColor="#D1D1D1"
                                android:textSize="13sp" />
                            <TextView
                                android:id="@+id/txtSoDu"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 VNĐ"
                                android:textColor="@color/trang"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_naptien"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_nut_nap_tien"
                            android:paddingHorizontal="18dp"
                            android:text="Nạp tiền"
                            android:textAllCaps="false"
                            android:textColor="@color/trang"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:elevation="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/khu_vuc_menu_doc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical"
                android:paddingHorizontal="15dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="3dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="15dp">

                        <ImageButton
                            android:id="@+id/img_btn_datcho"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:layout_centerVertical="true"
                            android:background="@android:color/transparent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/xe"/>

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_text_datcho"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toEndOf="@id/img_btn_datcho"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingStart="20dp"
                            android:text="Đặt chỗ đỗ xe"
                            android:textAllCaps="false"
                            android:textColor="@color/chu_tieude"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="3dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="15dp">

                        <ImageButton
                            android:id="@+id/img_btn_qr"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:layout_centerVertical="true"
                            android:background="@android:color/transparent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/quetqr"/>

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_text_qr"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toEndOf="@id/img_btn_qr"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingStart="20dp"
                            android:text="Gữi xe"
                            android:textAllCaps="false"
                            android:textColor="@color/chu_tieude"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
                <!-- Nút Xe đã gửi (Thêm mới bên dưới nút Gửi xe) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="3dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="15dp">

                        <ImageButton
                            android:id="@+id/img_btn_xe_da_gui"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:layout_centerVertical="true"
                            android:background="@android:color/transparent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/baidau1"/> <!-- Bạn có thể thay @drawable/xe_lichsu nếu có -->

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_text_xe_da_gui"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toEndOf="@id/img_btn_xe_da_gui"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingStart="20dp"
                            android:text="Danh sách xe đang gữi"
                            android:textAllCaps="false"
                            android:textColor="@color/chu_tieude"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="3dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="15dp">

                        <ImageButton
                            android:id="@+id/img_btn_parking"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:layout_centerVertical="true"
                            android:background="@android:color/transparent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/baidau1"/>

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_text_parking"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toEndOf="@id/img_btn_parking"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingStart="20dp"
                            android:text="Thông tin bãi xe"
                            android:textAllCaps="false"
                            android:textColor="@color/chu_tieude"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="3dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="15dp">

                        <ImageButton
                            android:id="@+id/img_btn_phuongtien"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:layout_centerVertical="true"
                            android:background="@android:color/transparent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/xe"/>

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_text_phuongtien"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toEndOf="@id/img_btn_phuongtien"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingStart="20dp"
                            android:text="Quản lý phương tiện"
                            android:textAllCaps="false"
                            android:textColor="@color/chu_tieude"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.cardview.widget.CardView
        android:id="@+id/khung_menu_duoi"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/trang"
            android:orientation="horizontal"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/btn_trangchu"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="@color/xanh_dam_chuyen_nghiep" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trang chủ"
                    android:textColor="@color/xanh_dam_chuyen_nghiep"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/btn_taikhoan"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="#999999" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tài khoản"
                    android:textColor="#999999"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageButton
                    android:id="@+id/btn_dangxuat"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="#FF5252" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng xuất"
                    android:textColor="#FF5252"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
