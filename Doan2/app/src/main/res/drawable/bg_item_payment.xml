<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape>
            <solid android:color="#F0F7FF" /> <stroke
            android:width="2dp"
            android:color="@color/xanh_dam_chuyen_nghiep" /> <corners android:radius="12dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/trang" />
            <stroke
                android:width="1dp"
                android:color="#E0E0E0" /> <corners android:radius="12dp" />
        </shape>
    </item>
</selector>